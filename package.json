{
	"name": "cdk-s3www",
	"version": "0.1.0",
	"bin": {
		"cdk-s3www": "bin/cdk-s3www.js"
	},
	"scripts": {
		"preinstall": "pnpm audit",
		"format": "oxfmt",
		"lint": "oxlint",
		"check": "oxfmt && oxlint --fix",
		"bootstrap": "NPM_CONFIG_LOGLEVEL=error cdk bootstrap",
		"list": "NPM_CONFIG_LOGLEVEL=error cdk list",
		"synth": "NPM_CONFIG_LOGLEVEL=error cdk synth",
		"deploy": "NPM_CONFIG_LOGLEVEL=error cdk deploy --outputs-file outputs.tmp.json",
		"deploy:hotswap": "NPM_CONFIG_LOGLEVEL=error cdk deploy --hotswap --outputs-file outputs.tmp.json",
		"diff": "NPM_CONFIG_LOGLEVEL=error cdk diff",
		"destroy": "NPM_CONFIG_LOGLEVEL=error cdk destroy"
	},
	"dependencies": {
		"aws-cdk-lib": "2.250.0",
		"constructs": "^10.6.0"
	},
	"devDependencies": {
		"@types/jest": "^30.0.0",
		"@types/node": "25.6.0",
		"aws-cdk": "2.1119.0",
		"jest": "^30.3.0",
		"ts-jest": "^29.4.9",
		"ts-node": "^10.9.2",
		"tsx": "^4.21.0",
		"typescript": "~6.0.3"
	}
}
